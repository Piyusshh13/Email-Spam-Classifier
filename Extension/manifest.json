{
  "manifest_version": 3,
  "name": "Spam Email Detector Pro",
  "description": "An AI-powered email classification extension utilizing real-time ML confidence metrics.",
  "version": "1.2",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://email-spam-classifier-caa0.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}